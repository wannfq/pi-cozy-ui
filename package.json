{
  "name": "pi-cozy-ui",
  "version": "0.2.5",
  "description": "Cozy UI for Pi — left-bar input box, startup screen, and cozy themes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wannfq/pi-cozy-ui.git"
  },
  "homepage": "https://github.com/wannfq/pi-cozy-ui#readme",
  "bugs": {
    "url": "https://github.com/wannfq/pi-cozy-ui/issues"
  },
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent"
  ],
  "packageManager": "pnpm@11.1.0",
  "files": [
    "extensions",
    "lib/editor-layout.ts",
    "lib/git-status.ts",
    "lib/text-layout.ts",
    "themes"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "image": "https://raw.githubusercontent.com/wannfq/pi-cozy-ui/main/docs/preview.png",
    "extensions": [
      "./extensions/input-field.ts",
      "./extensions/startup-screen.ts"
    ],
    "themes": [
      "./themes"
    ]
  },
  "scripts": {
    "dev": "pi --no-extensions --no-themes --theme ./themes/cozy-dark.json -e ./extensions/input-field.ts -e ./extensions/startup-screen.ts",
    "dev:light": "pi --no-extensions --no-themes --theme ./themes/cozy-light.json -e ./extensions/input-field.ts -e ./extensions/startup-screen.ts",
    "check": "tsc --noEmit --strict --module esnext --moduleResolution bundler --target es2022 --skipLibCheck extensions/input-field.ts extensions/startup-screen.ts lib/text-layout.ts lib/editor-layout.ts lib/git-status.ts",
    "test": "vitest run",
    "dev:startup": "pi --no-extensions -e ./extensions/startup-screen.ts",
    "dev:input": "pi --no-extensions -e ./extensions/input-field.ts"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": false
    },
    "@earendil-works/pi-tui": {
      "optional": false
    }
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.81.0",
    "@earendil-works/pi-tui": "^0.81.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
